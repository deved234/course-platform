    {
      "name": "Courses",
      "item": [
        {
          "name": "Create Course (Instructor)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const jsonData = pm.response.json();",
